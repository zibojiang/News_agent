# AI 提供方：openai（默认）、gemini 或 deepseek
AI_PROVIDER=openai

# DeepSeek 配置（AI_PROVIDER=deepseek 时使用）
# DeepSeek 兼容 OpenAI API，需要设置 OPENAI_BASE_URL
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
# OPENAI_API_KEY=your_deepseek_api_key_here

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# 可选：切换 AI_PROVIDER=gemini 时使用
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Agent 与本地存储配置
DATABASE_PATH=data/industry_news.db
TOPICS_XLSX_PATH=复星旅文DeepResearch研究主题目录_更新版_V4.xlsx
DEPLOYMENT_MODE=local
ADMIN_PASSWORD=replace_with_a_strong_password

# 独立定时 worker 每隔多少分钟扫描到期主题
SCHEDULER_POLL_MINUTES=30
MAX_TOPICS_PER_CYCLE=2
TZ=Asia/Shanghai
