# 将以下内容粘贴到 Streamlit Community Cloud 的 Advanced settings > Secrets。
# 不要把真实值写入 GitHub 仓库。

AI_PROVIDER = "openai"
OPENAI_API_KEY = "1"
OPENAI_MODEL = "gpt-5.6-luna"

# 如果改用 Gemini，请把 AI_PROVIDER 改为 "gemini" 并填写以下两项。
GEMINI_API_KEY = "your_gemini_api_key_here"
GEMINI_MODEL = "gemini-flash-latest"
ADMIN_PASSWORD = "replace_with_a_strong_password"
DEPLOYMENT_MODE = "cloud_demo"
DATABASE_PATH = "data/industry_news.db"
TOPICS_XLSX_PATH = "复星旅文DeepResearch研究主题目录_更新版_V4.xlsx"
SCHEDULER_POLL_MINUTES = "30"
MAX_TOPICS_PER_CYCLE = "2"
TZ = "Asia/Shanghai"
